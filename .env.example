# ==============================================================================
# .env.example — All environment variables Realive needs
#
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env   (Windows)
#   2. Fill in your real values in .env
#   3. NEVER commit .env to git — it contains secrets
#
# Each variable is explained below. We'll fill these in milestone by milestone.
# ==============================================================================

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=true

# ── Supabase (set up in Milestone 1) ──────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# ^ Use the SERVICE ROLE key (not the anon key) — backend needs full DB access

# ── GitHub App (set up in Milestone 2) ────────────────────────────────────────
# Get these after registering your GitHub App at:
# https://github.com/settings/apps/new
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# ^ Paste the full private key PEM here, with \n for newlines
GITHUB_WEBHOOK_SECRET=a-random-secret-string-you-choose

# ── Gemini API (used from Milestone 4 onwards) ─────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
